# Public site URL, used for metadata, sitemap and robots.txt
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Resend (https://resend.com) API key used to send career-application emails
RESEND_API_KEY=

# Mailbox that receives new "Trabalhe conosco" applications
CAREER_NOTIFICATION_EMAIL=financeiro@m4irmaos.com

# Sender address; must be on a domain verified in Resend
CAREER_FROM_EMAIL=candidaturas@m4irmaos.com
